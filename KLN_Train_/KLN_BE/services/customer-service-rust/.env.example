SERVICE_NAME=customer-service
PORT=4005

# Nếu DB_SERVER là named instance (vd '\SQLEXPRESS'), đây PHẢI là cổng TCP
# tĩnh thật sự của instance đó, không phải 1433 mặc định — tiberius (khác
# tedious bên Node) không tự dò cổng động qua SQL Browser (UDP 1434). Lấy cổng
# thật bằng cách: Get-Service "*SQL*" để tìm PID của MSSQL$<tên_instance>, rồi
# Get-NetTCPConnection -State Listen | Where OwningProcess -eq <PID>. Để ổn
# định lâu dài, nên đặt cổng tĩnh cho instance qua SQL Server Configuration
# Manager thay vì phụ thuộc cổng động có thể đổi khi service khởi động lại.
DB_SERVER='localhost\SQLEXPRESS'
DB_NAME=Trainn
DB_USER=sa
DB_PASSWORD=18082005Linhn
DB_PORT=1433

INTERNAL_API_KEY=kln_internal_dev_key_change_in_production
